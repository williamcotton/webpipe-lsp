{
  "name": "webpip-lsp",
  "displayName": "Web Pipe",
  "description": "Web Pipe",
  "version": "2.0.72",
  "publisher": "williamcotton",
  "author": {
    "name": "William Cotton",
    "email": "williamcotton@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/williamcotton/webpipe"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "main": "./client/out/extension.js",
  "bin": {
    "webpipe-lsp": "./server/out/cli.js"
  },
  "files": [
    "README.md",
    "language-configuration.json",
    "syntaxes/**/*",
    "client/out/**/*",
    "server/out/**/*"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "scripts": {
    "compile": "npm run compile:client && npm run compile:server",
    "compile:client": "tsc -b client",
    "compile:server": "tsc -b server",
    "check": "node ./server/out/cli.js check",
    "watch": "tsc -b -w client server",
    "postinstall": "node ./client/postinstall.js || true",
    "prepack": "npm run compile",
    "vscode:prepublish": "npm run compile",
    "package": "npx @vscode/vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "webpipe",
        "aliases": [
          "Web Pipe",
          "webpipe"
        ],
        "extensions": [
          ".wp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "webpipe",
        "scopeName": "source.webpipe",
        "path": "./syntaxes/webpipe.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.sql": "sql",
          "meta.embedded.block.jq": "jq",
          "meta.embedded.block.lua": "lua",
          "meta.embedded.block.js": "javascript",
          "meta.embedded.js.webpipe": "javascript",
          "meta.embedded.block.mustache": "mustache"
        }
      }
    ],
    "breakpoints": [
      {
        "language": "webpipe"
      }
    ],
    "debuggers": [
      {
        "type": "webpipe",
        "label": "Web Pipe Debug",
        "languages": [
          "webpipe"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to .wp file to debug",
                "default": "${file}"
              },
              "port": {
                "type": "number",
                "description": "HTTP server port",
                "default": 7770
              },
              "debugPort": {
                "type": "number",
                "description": "DAP debug port",
                "default": 5858
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "webpipe",
            "request": "launch",
            "name": "Debug Web Pipe",
            "program": "${file}",
            "port": 7770,
            "debugPort": 5858,
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Web Pipe: Debug",
            "description": "Debug a Web Pipe .wp file",
            "body": {
              "type": "webpipe",
              "request": "launch",
              "name": "Debug Web Pipe",
              "program": "^\"\\${file}\"",
              "port": 7770,
              "debugPort": 5858,
              "stopOnEntry": false
            }
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.39",
    "@types/vscode": "^1.89.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.1.0",
    "webpipe-js": "^2.0.71"
  }
}
