{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Web Pipe",
  "scopeName": "source.webpipe",
  "fileTypes": [
    "wp"
  ],
  "patterns": [
    {
      "include": "#config-definition"
    },
    {
      "include": "#route-definition"
    },
    {
      "include": "#variable-assignment"
    },
    {
      "include": "#assertion-output-jq"
    },
    {
      "include": "#assertion-call-jq"
    },
    {
      "include": "#test-input-jq"
    },
    {
      "include": "#test-spec-keywords"
    },
    {
      "include": "#backtick-json"
    },
    {
      "include": "#triple-quote-strings"
    }
    ,
    {
      "include": "#general-numbers"
    },
    {
      "include": "#comments"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.webpipe",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.webpipe",
          "match": "//.*$"
        }
      ]
    },
    "config-definition": {
      "patterns": [
        {
          "begin": "^\\s*(config)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.config.webpipe"
            },
            "2": {
              "name": "entity.name.type.config.webpipe"
            }
          },
          "end": "\\}",
          "name": "meta.config-block.webpipe",
          "patterns": [
            {
              "include": "#config-content"
            }
          ]
        }
      ]
    },
    "route-definition": {
      "patterns": [
        {
          "begin": "^\\s*(GET|POST|PUT|DELETE)\\s+([^\\s]+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.http-method.webpipe"
            },
            "2": {
              "name": "string.unquoted.route-path.webpipe",
              "patterns": [
                {
                  "match": ":[a-zA-Z_][a-zA-Z0-9_-]*",
                  "name": "variable.parameter.route.webpipe"
                }
              ]
            }
          },
          "end": "^(?!\\s*\\|>)(?=\\S|$)",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        }
      ]
    },
    "variable-assignment": {
      "patterns": [
        {
          "begin": "^\\s*(graphqlSchema)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.graphql.webpipe"
            }
          },
          "end": "`",
          "name": "meta.graphql-schema.webpipe",
          "contentName": "source.graphql",
          "patterns": [
            {
              "include": "source.graphql"
            }
          ]
        },
        {
          "begin": "^\\s*(query)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
          "beginCaptures": {
            "1": {
              "name": "storage.type.graphql.query.webpipe"
            },
            "2": {
              "name": "entity.name.function.query.webpipe"
            }
          },
          "end": "^(?!\\s*\\|>)(?=\\S|$)",
          "name": "meta.query-resolver.webpipe",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "begin": "^\\s*(mutation)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
          "beginCaptures": {
            "1": {
              "name": "storage.type.graphql.mutation.webpipe"
            },
            "2": {
              "name": "entity.name.function.mutation.webpipe"
            }
          },
          "end": "^(?!\\s*\\|>)(?=\\S|$)",
          "name": "meta.mutation-resolver.webpipe",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "begin": "^\\s*(featureFlags)\\s*=",
          "beginCaptures": {
            "1": {
              "name": "storage.type.feature-flags.webpipe"
            }
          },
          "end": "^(?!\\s*\\|>)(?=\\S|$)",
          "name": "meta.feature-flags.webpipe",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "begin": "^\\s*(pipeline)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "^(?!\\s*\\|>)(?=\\S|$)",
          "name": "meta.variable-assignment.pipeline.webpipe",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "begin": "^\\s*(jq)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.jq.webpipe",
          "contentName": "source.jq",
          "patterns": [
            {
              "include": "#jq-embedded"
            }
          ]
        },
        {
          "begin": "^\\s*(lua)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.lua.webpipe",
          "contentName": "source.lua",
          "patterns": [
            {
              "include": "source.lua"
            }
          ]
        },
        {
          "begin": "^\\s*(pg)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.sql.webpipe",
          "contentName": "source.sql",
          "patterns": [
            {
              "include": "#sql-string-override"
            },
            {
              "include": "source.sql"
            }
          ]
        },
        {
          "begin": "^\\s*(graphql)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.graphql.webpipe",
          "contentName": "source.graphql",
          "patterns": [
            {
              "include": "source.graphql"
            }
          ]
        },
        {
          "begin": "^\\s*(mustache)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.mustache.webpipe",
          "contentName": "text.html.mustache",
          "patterns": [
            {
              "include": "#mustache-embedded"
            }
          ]
        },
        {
          "begin": "^\\s*(mustache)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*\"\"\"",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "\"\"\"",
          "name": "meta.variable-assignment.mustache.triple.webpipe",
          "contentName": "text.html.mustache",
          "patterns": [
            {
              "include": "#mustache-embedded"
            }
          ]
        },
        {
          "begin": "^\\s*(handlebars)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.handlebars.webpipe",
          "contentName": "text.html.mustache",
          "patterns": [
            {
              "include": "#mustache-embedded"
            }
          ]
        },
        {
          "begin": "^\\s*(validate)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*`",
          "beginCaptures": {
            "1": {
              "name": "storage.type.middleware.webpipe"
            },
            "2": {
              "name": "variable.other.assignment.webpipe"
            }
          },
          "end": "`",
          "name": "meta.variable-assignment.validate.webpipe",
          "contentName": "source.validate.webpipe",
          "patterns": [
            {
              "include": "#validate-embedded"
            }
          ]
        }
      ]
    },
    "pipeline-steps": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#middleware-step"
        },
        {
          "include": "#result-step"
        },
        {
          "include": "#if-step"
        },
        {
          "include": "#dispatch-step"
        },
        {
          "include": "#foreach-step"
        },
        {
          "include": "#pipeline-operator"
        },
        {
          "include": "#tags"
        }
      ]
    },
    "pipeline-operator": {
      "match": "^\\s*(\\|>)|(?<=\\s)(\\|>)",
      "captures": {
        "1": {
          "name": "keyword.operator.pipe.webpipe"
        },
        "2": {
          "name": "keyword.operator.pipe.webpipe"
        }
      }
    },
    "middleware-step": {
      "patterns": [
        {
          "begin": "^\\s*(\\|>)\\s*(jq)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.jq.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.jq.webpipe",
              "contentName": "source.jq",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(lua)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.lua.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.lua.webpipe",
              "contentName": "source.lua",
              "patterns": [ { "include": "source.lua" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(pg)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.pg.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.sql.webpipe",
              "contentName": "source.sql",
              "patterns": [
                { "include": "#sql-string-override" },
                { "include": "source.sql" }
              ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(mustache)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.mustache.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.mustache.webpipe",
              "contentName": "text.html.mustache",
              "patterns": [ { "include": "#mustache-embedded" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(handlebars)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.handlebars.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.handlebars.webpipe",
              "contentName": "text.html.mustache",
              "patterns": [ { "include": "#mustache-embedded" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(validate)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.validate.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.validate.webpipe",
              "contentName": "source.validate.webpipe",
              "patterns": [ { "include": "#validate-embedded" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(graphql)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.graphql.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(",
              "end": "\\)",
              "beginCaptures": { "0": { "name": "meta.parens.webpipe" } },
              "endCaptures": { "0": { "name": "meta.parens.webpipe" } },
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[",
              "end": "\\]",
              "beginCaptures": { "0": { "name": "meta.brackets.webpipe" } },
              "endCaptures": { "0": { "name": "meta.brackets.webpipe" } },
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.graphql.webpipe",
              "contentName": "source.graphql",
              "patterns": [ { "include": "source.graphql" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "begin": "^\\s*(\\|>)\\s*(join)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.join.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(", "end": "\\)",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[", "end": "\\]",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "begin": "`",
              "end": "`",
              "name": "meta.embedded.join.webpipe",
              "patterns": [ { "include": "#join-config" } ]
            },
            {
              "begin": "\"",
              "end": "\"",
              "name": "meta.embedded.join.webpipe",
              "patterns": [ { "include": "#join-config" } ]
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        },
        {
          "comment": "Generic middleware capture (handles fetch, log, etc with arguments)",
          "begin": "^\\s*(\\|>)\\s*([a-zA-Z_][a-zA-Z0-9_-]*)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.pipe.webpipe" },
            "2": { "name": "entity.name.function.middleware.webpipe" }
          },
          "end": "(?=$|\\s*\\|>|\\s*@)",
          "patterns": [
            {
              "begin": "\\(",
              "end": "\\)",
              "beginCaptures": { "0": { "name": "meta.parens.webpipe" } },
              "endCaptures": { "0": { "name": "meta.parens.webpipe" } },
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "begin": "\\[",
              "end": "\\]",
              "beginCaptures": { "0": { "name": "meta.brackets.webpipe" } },
              "endCaptures": { "0": { "name": "meta.brackets.webpipe" } },
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value.webpipe"
            },
            {
              "comment": "Config: Backtick",
              "begin": "`",
              "end": "`",
              "name": "string.quoted.other.backtick.webpipe",
              "patterns": [ { "include": "#jq-embedded" } ]
            },
            {
              "comment": "Config: Double Quote",
              "begin": "\"",
              "end": "\"",
              "name": "string.quoted.double.webpipe"
            },
            {
              "comment": "Config: Identifier",
              "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
              "name": "variable.other.webpipe"
            },
            { "include": "#tags" },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "result-step": {
      "begin": "^\\s*(\\|>)\\s*(result)\\s*$",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.pipe.webpipe"
        },
        "2": {
          "name": "keyword.control.result.webpipe"
        }
      },
      "end": "^(?!\\s*[a-zA-Z]+\\(\\d+\\):)(?!\\s*\\|>)(?=\\S|$)",
      "patterns": [
        {
          "include": "#result-conditions"
        }
      ]
    },
    "result-conditions": {
      "patterns": [
        {
          "begin": "^\\s*([a-zA-Z]+)\\((\\d+)\\):",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.condition.webpipe"
            },
            "2": {
              "name": "constant.numeric.status-code.webpipe"
            }
          },
          "end": "^(?=\\s*[a-zA-Z]+\\(\\d+\\):|^(?!\\s*\\|>)\\S|$)",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        }
      ]
    },
    "if-step": {
      "begin": "^\\s*(\\|>)\\s*(if)\\s*$",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.pipe.webpipe"
        },
        "2": {
          "name": "keyword.control.if.webpipe"
        }
      },
      "end": "^(?!\\s*then:|\\s*else:|\\s*\\|>)(?=\\S|$)",
      "patterns": [
        {
          "include": "#if-branches"
        }
      ]
    },
    "if-branches": {
      "patterns": [
        {
          "match": "^\\s*(end)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.end.webpipe"
            }
          }
        },
        {
          "begin": "^\\s*(then):",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.then.webpipe"
            }
          },
          "end": "^(?=\\s*else:|\\s*end\\b|^(?!\\s*\\|>)\\S|$)",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "begin": "^\\s*(else):",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.else.webpipe"
            }
          },
          "end": "^(?=\\s*end\\b|^(?!\\s*\\|>)\\S|$)",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#pipeline-steps"
            }
          ]
        },
        {
          "include": "#comments"
        },
        {
          "include": "#pipeline-steps"
        }
      ]
    },
    "dispatch-step": {
      "begin": "^\\s*(\\|>)\\s*(dispatch)\\s*$",
      "beginCaptures": {
        "1": {
